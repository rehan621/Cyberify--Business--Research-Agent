# ================================================
# Cyberify Research Agent — Environment Variables
# ================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── OpenAI ───────────────────────────────────────
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Tavily Web Search ─────────────────────────────
# Get your key: https://app.tavily.com (free plan available)
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# ── PostgreSQL Database ───────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/cyberify_db

# ── JWT Authentication ────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-minimum-32-characters-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── App Settings ──────────────────────────────────
APP_NAME=Cyberify Research Agent
DEBUG=True